{
  "name": "@tinycloud/listen-cli",
  "version": "0.1.0",
  "description": "CLI importer for TinyCloud Listen",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "listen": "./dist/listen"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/listen --external:better-sqlite3 && chmod +x dist/listen",
    "check": "tsc --noEmit",
    "changeset": "changeset",
    "prepack": "npm run build",
    "release": "npm publish",
    "test": "vitest run",
    "version": "changeset version",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.0",
    "esbuild": "^0.28.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@tinycloud/cli": "0.7.0-beta.5",
    "@tinycloud/node-sdk": "2.4.0-beta.3",
    "better-sqlite3": "^12.11.1"
  }
}
